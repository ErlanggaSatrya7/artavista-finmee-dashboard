<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="ArtavistaUI" constructor="ArtavistaDashboard" version="1.1.2"
    display-name-key="Artavista Sales Dashboard"
    description-key="Dashboard Operasional Artavista: Integrasi Transaksi, Produk, Klien, dan Jadwal Proyek."
    control-type="virtual">
    
    <external-service-usage enabled="false" />

    <property name="UserName"       display-name-key="Nama Pengguna"          of-type="SingleLine.Text" usage="bound" required="true" />
    <property name="TotalTask"      display-name-key="Total Omzet (Manual/Dummy)" of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="UserRole"       display-name-key="Role: Admin / Sales"    of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="ClickedAction"  display-name-key="Output: Sinyal Tombol"  of-type="SingleLine.Text" usage="output" required="false" />
    <property name="SelectedRecordId" display-name-key="Output: ID Data Terpilih" of-type="SingleLine.Text" usage="output" required="false" />
    <property name="LogoInput"      display-name-key="URL Logo Perusahaan"    of-type="SingleLine.Text" usage="bound" required="false" />
    <property name="BannerInput"    display-name-key="URL Banner Dashboard"   of-type="SingleLine.Text" usage="bound" required="false" />

    <data-set name="ContentList" display-name-key="Dataset: Transaksi Penjualan">
      <property-set name="colTitle"    display-name-key="Kolom: Nama Layanan"         of-type="SingleLine.Text" usage="bound" required="true" />
      <property-set name="colPlatform" display-name-key="Kolom: Nama Pelanggan"        of-type="SingleLine.Text" usage="bound" required="true" />
      <property-set name="colDate"     display-name-key="Kolom: Tanggal Order"         of-type="SingleLine.Text" usage="bound" required="true" />
      <property-set name="colStatus"   display-name-key="Kolom: Status Pembayaran"     of-type="SingleLine.Text" usage="bound" required="true" />
      <property-set name="colAmount"   display-name-key="Kolom: Nilai Proyek (Uang)"   of-type="SingleLine.Text" usage="bound" required="false" />
    </data-set>

    <data-set name="ProductList" display-name-key="Dataset: Katalog Produk">
      <property-set name="colProdName"     display-name-key="Kolom: Nama Produk"        of-type="SingleLine.Text" usage="bound" required="true" />
      <property-set name="colProdCategory" display-name-key="Kolom: Kategori"           of-type="SingleLine.Text" usage="bound" required="true" />
      <property-set name="colProdPrice"    display-name-key="Kolom: Harga"              of-type="SingleLine.Text" usage="bound" required="true" />
      <property-set name="colProdSold"     display-name-key="Kolom: Total Terjual"      of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colProdDesc"     display-name-key="Kolom: Deskripsi"          of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colProdImage"    display-name-key="Kolom: URL Gambar"         of-type="SingleLine.Text" usage="bound" required="false" />
    </data-set>

    <data-set name="CustomerList" display-name-key="Dataset: Daftar Klien">
      <property-set name="colCustName"    display-name-key="Kolom: Nama Perusahaan"      of-type="SingleLine.Text" usage="bound" required="true" />
      <property-set name="colCustContact" display-name-key="Kolom: Nama PIC"             of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colCustEmail"   display-name-key="Kolom: Email"                of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colCustPhone"   display-name-key="Kolom: No. Telepon/WA"       of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colCustSpent"   display-name-key="Kolom: Total Revenue Klien"  of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colCustStatus"  display-name-key="Kolom: Status Hubungan"      of-type="SingleLine.Text" usage="bound" required="false" />
    </data-set>

    <data-set name="ScheduleList" display-name-key="Dataset: Jadwal Proyek">
      <property-set name="colSchedTitle"    display-name-key="Kolom: Nama Proyek"        of-type="SingleLine.Text" usage="bound" required="true" />
      <property-set name="colSchedClient"   display-name-key="Kolom: Klien Terkait"      of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colSchedStart"    display-name-key="Kolom: Tanggal Mulai"      of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colSchedDeadline" display-name-key="Kolom: Deadline"           of-type="SingleLine.Text" usage="bound" required="true" />
      <property-set name="colSchedProgress" display-name-key="Kolom: Progress (0-100)"   of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colSchedStatus"   display-name-key="Kolom: Status Kerja"       of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colSchedPIC"      display-name-key="Kolom: PIC Proyek"         of-type="SingleLine.Text" usage="bound" required="false" />
      <property-set name="colSchedNotes"    display-name-key="Kolom: Catatan Internal"   of-type="SingleLine.Text" usage="bound" required="false" />
    </data-set>

    <resources>
      <code path="index.ts" order="1"/>
      <css path="css/ArtavistaStyle.css" order="1" />
      <img path="img/logo-artavista.png" />
      <img path="img/card-banner1.png" />
      <platform-library name="React" version="16.14.0" />
    </resources>
  </control>
</manifest>